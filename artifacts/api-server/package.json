    "@types/ffmpeg-static": "^5.1.0",
    "@types/web-push": "^3.6.4",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "resend": "^6.12.4",
    "web-push": "^3.6.7",
